# ═══════════════════════════════════════════════════
# Virtual Protocol ACP 설정
# 이 파일을 .env로 복사한 후 값을 채우세요
# cp .env.example .env
# ═══════════════════════════════════════════════════

# 지갑 개인키 (MetaMask에서 Export)
# 주의: 절대 공유하지 마세요!
WHITELISTED_WALLET_PRIVATE_KEY=0x

# ACP 등록 후 받는 값들 (app.virtuals.io에서 확인)
SESSION_ENTITY_KEY_ID=
AGENT_WALLET_ADDRESS=0x

# 네트워크 설정
# testnet: Base Sepolia (테스트용)
# mainnet: Base (실제 운영용)
NETWORK=testnet

# ═══════════════════════════════════════════════════
# 바이어 테스트 에이전트 (Sandbox 10건 거래용)
# 별도의 바이어 에이전트를 등록한 후 채우세요
# ═══════════════════════════════════════════════════
BUYER_WALLET_PRIVATE_KEY=0x
BUYER_ENTITY_KEY_ID=
BUYER_WALLET_ADDRESS=0x

# ═══════════════════════════════════════════════════
# SEC EDGAR API (선택)
# ═══════════════════════════════════════════════════

# SEC는 실제 이름+이메일을 User-Agent에 넣을 것을 요구합니다
# 프로덕션에서는 반드시 변경하세요
SEC_EDGAR_USER_AGENT=YourName your@email.com
