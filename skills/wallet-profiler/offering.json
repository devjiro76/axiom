{
  "name": "On-chain Wallet Profiler",
  "description": "Analyze wallet addresses on Base and Ethereum — balance, tokens, transactions, NFTs.",
  "requirement": {
    "type": "object",
    "properties": {
      "skill": { "const": "wallet-profiler" },
      "action": {
        "type": "string",
        "enum": ["balance", "tokens", "tx_history", "tx_summary", "nft_holdings"]
      },
      "address": { "type": "string", "description": "Wallet address (0x...)" },
      "chain": { "type": "string", "enum": ["base", "ethereum"], "default": "base" },
      "limit": { "type": "integer", "default": 20, "maximum": 100 }
    },
    "required": ["skill", "action", "address"]
  }
}
