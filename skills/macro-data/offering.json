{
  "name": "US Macro Data",
  "description": "US macroeconomic indicators via FRED — interest rates, GDP, employment, inflation, and more.",
  "requirement": {
    "type": "object",
    "properties": {
      "skill": { "const": "macro-data" },
      "action": {
        "type": "string",
        "enum": ["search", "series", "popular", "compare"]
      },
      "query": { "type": "string", "description": "Search query (for 'search')" },
      "seriesId": { "type": "string", "description": "FRED series ID (for 'series')" },
      "seriesIds": { "type": "array", "items": { "type": "string" }, "description": "Multiple series IDs (for 'compare')" },
      "startDate": { "type": "string", "description": "Start date YYYY-MM-DD" },
      "endDate": { "type": "string", "description": "End date YYYY-MM-DD" },
      "frequency": { "type": "string", "description": "Data frequency (d, w, m, q, a)" },
      "limit": { "type": "integer", "default": 10, "maximum": 100 }
    },
    "required": ["skill", "action"]
  }
}
