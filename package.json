{
  "name": "axiom-data-mcp",
  "version": "1.0.0",
  "description": "Financial & research data MCP server — SEC filings, DeFi analytics, wallet profiling, academic papers, US macro data, patent search, token sentiment. 30 tools for AI agents.",
  "type": "module",
  "bin": {
    "axiom-data-mcp": "dist/adapters/mcp-server/server.js"
  },
  "files": [
    "dist/adapters/mcp-server",
    "dist/skills",
    "dist/lib"
  ],
  "scripts": {
    "search": "tsx skills/sec-edgar/cli.ts search",
    "lookup": "tsx skills/sec-edgar/cli.ts lookup",
    "fetch": "tsx skills/sec-edgar/cli.ts fetch",
    "filings": "tsx skills/sec-edgar/cli.ts filings",
    "test": "tsx skills/sec-edgar/test.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "start": "tsx adapters/virtuals-acp/seller.ts",
    "seller": "tsx adapters/virtuals-acp/seller.ts",
    "buyer:test": "tsx adapters/virtuals-acp/buyer-test.ts",
    "mcp": "tsx adapters/mcp-server/server.ts"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "ai-agent",
    "sec-edgar",
    "defi",
    "crypto",
    "financial-data",
    "macro-economics",
    "patent-search",
    "academic-papers",
    "token-sentiment",
    "wallet-profiler"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/devjiro76/axiom"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@virtuals-protocol/acp-node": "^0.3.0-beta.37",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "apify": "^3.6.0",
    "cheerio": "^1.2.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "dotenv": "^17.3.1"
  }
}
